# =====================================================
# CineNova — Environment Variables (sample)
# Copy to .env and fill in values for local development
# =====================================================

# --- Node runtime ---
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://cinenova:cinenova@localhost:5432/cinenova?schema=public
DIRECT_URL=postgresql://cinenova:cinenova@localhost:5432/cinenova?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth (Auth.js v5) ---
AUTH_SECRET=replace-with-32-byte-random-hex
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
JWT_SECRET=replace-with-32-byte-random-hex
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
QR_TOKEN_SECRET=replace-with-32-byte-random-hex

# --- Service-to-service (api ↔ ai) ---
SERVICE_TOKEN_SECRET=replace-with-32-byte-random-hex

# --- AI service ---
AI_SERVICE_URL=http://localhost:5000
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# --- TMDb ---
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/original

# --- Payment (sandbox) ---
PAYMENT_PROVIDER=vnpay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/booking/return
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Object storage ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cinenova
S3_ACCESS_KEY=cinenova
S3_SECRET_KEY=cinenovasecret
S3_FORCE_PATH_STYLE=true

# --- Email ---
EMAIL_PROVIDER=mailhog
MAILHOG_HOST=localhost
MAILHOG_PORT=1025
RESEND_API_KEY=
EMAIL_FROM="CineNova <noreply@cinenova.local>"

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500

# --- Rate limiting ---
RATE_LIMIT_AI_PER_MIN=10
RATE_LIMIT_API_PER_MIN=120
